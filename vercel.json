{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "PLAYWRIGHT_BROWSERS_PATH=0 python -m playwright install --only-shell chromium",
  "env": {
    "PLAYWRIGHT_BROWSERS_PATH": "0"
  },
  "crons": [
    {
      "path": "/api/market_open",
      "schedule": "30 13 * * 1-5"
    },
    {
      "path": "/api/market_open",
      "schedule": "30 14 * * 1-5"
    }
  ]
}
